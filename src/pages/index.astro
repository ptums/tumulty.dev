---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout>
  <!-- ============================================================
       NAV
  ============================================================ -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-100">
    <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between" aria-label="Main navigation">

      <!-- Logo -->
      <a href="/" class="font-display text-xl font-bold text-emerald-800 tracking-tight hover:text-emerald-600 transition-colors">
        Tumulty
      </a>

      <!-- Desktop nav links (hidden on mobile) -->
      <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
        <li>
          <a href="#services" class="text-sm text-gray-600 hover:text-emerald-600 transition-colors">
            Services
          </a>
        </li>
        <li>
          <a href="#about" class="text-sm text-gray-600 hover:text-emerald-600 transition-colors">
            About
          </a>
        </li>
        <li>
          <a href="#contact" class="text-sm text-gray-600 hover:text-emerald-600 transition-colors">
            Contact
          </a>
        </li>
      </ul>

      <!-- CTA — always visible -->
      <a
        href="https://audit.tumulty.dev"
        class="inline-block bg-emerald-800 text-white text-sm font-bold px-5 py-2.5 rounded-lg hover:bg-emerald-600 transition-colors"
      >
        Take the free audit
      </a>

    </nav>
  </header>

  <main>
    <!-- ============================================================
         HERO
    ============================================================ -->
    <section class="relative overflow-hidden bg-white">
      <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 lg:py-36 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

        <!-- Left: copy -->
        <div class="flex flex-col gap-6">
          <p class="text-xs font-bold uppercase tracking-widest text-emerald-600">
            AI Automation &amp; Digital Transformation
          </p>

          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight">
            AI that fits your business.<br />
            <span class="text-emerald-800">Not the other way around.</span>
          </h1>

          <p class="text-lg text-gray-600 leading-relaxed max-w-md">
            I help companies plug AI into the tools they already use — so your team works faster without learning a new system or overhauling how you operate.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href="https://audit.tumulty.dev"
              class="inline-block bg-emerald-800 text-white font-bold px-7 py-3.5 rounded-lg hover:bg-emerald-600 transition-colors"
            >
              Take the free audit
            </a>
            <a
              href="#services"
              class="inline-flex items-center gap-2 text-emerald-800 font-bold px-7 py-3.5 rounded-lg border-2 border-emerald-800 hover:bg-emerald-50 transition-colors"
            >
              See my work
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14M5 12l7 7 7-7"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: abstract shape -->
        <div class="hidden md:flex items-center justify-center" aria-hidden="true">
          <svg
            viewBox="0 0 480 480"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full max-w-sm lg:max-w-md"
          >
            <!-- Outer ring -->
            <circle cx="240" cy="240" r="210" fill="none" stroke="#065f46" stroke-width="1.5" opacity="0.12"/>
            <!-- Middle ring -->
            <circle cx="240" cy="240" r="150" fill="none" stroke="#065f46" stroke-width="1.5" opacity="0.18"/>
            <!-- Inner ring -->
            <circle cx="240" cy="240" r="90" fill="none" stroke="#065f46" stroke-width="1.5" opacity="0.24"/>

            <!-- Filled accent blobs -->
            <circle cx="310" cy="130" r="88" fill="#10b981" opacity="0.10"/>
            <circle cx="155" cy="330" r="64" fill="#065f46" opacity="0.08"/>
            <circle cx="350" cy="320" r="42" fill="#10b981" opacity="0.12"/>

            <!-- Orbital dots -->
            <circle cx="240" cy="30"  r="6" fill="#10b981" opacity="0.7"/>
            <circle cx="449" cy="240" r="5" fill="#065f46" opacity="0.5"/>
            <circle cx="240" cy="450" r="4" fill="#10b981" opacity="0.4"/>
            <circle cx="31"  cy="240" r="5" fill="#065f46" opacity="0.5"/>

            <!-- Diagonal dot accents -->
            <circle cx="391" cy="89"  r="4" fill="#10b981" opacity="0.6"/>
            <circle cx="391" cy="391" r="3" fill="#065f46" opacity="0.4"/>
            <circle cx="89"  cy="391" r="4" fill="#10b981" opacity="0.5"/>
            <circle cx="89"  cy="89"  r="3" fill="#065f46" opacity="0.4"/>

            <!-- Center dot -->
            <circle cx="240" cy="240" r="7" fill="#065f46" opacity="0.5"/>
            <circle cx="240" cy="240" r="3" fill="#10b981" opacity="0.9"/>

            <!-- Connector lines (subtle) -->
            <line x1="240" y1="30"  x2="449" y2="240" stroke="#10b981" stroke-width="0.75" opacity="0.15"/>
            <line x1="449" y1="240" x2="240" y2="450" stroke="#065f46" stroke-width="0.75" opacity="0.12"/>
            <line x1="240" y1="450" x2="31"  y2="240" stroke="#10b981" stroke-width="0.75" opacity="0.15"/>
            <line x1="31"  y1="240" x2="240" y2="30"  stroke="#065f46" stroke-width="0.75" opacity="0.12"/>
          </svg>
        </div>

      </div>
    </section>

    <!-- ============================================================
         SERVICES
    ============================================================ -->
    <section id="services" class="bg-gray-50 py-20 md:py-28">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Section header -->
        <div class="mb-14">
          <p class="text-xs font-bold uppercase tracking-widest text-emerald-600 mb-3">What I do</p>
          <h2 class="font-display text-3xl md:text-4xl font-extrabold text-gray-900">Services</h2>
        </div>

        <!-- Cards grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- Card: AI Workflow Automation -->
          <article class="bg-white rounded-xl border border-gray-200 p-8 flex flex-col gap-5 hover:shadow-lg transition-shadow">
            <div class="text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="4" r="2"/>
                <circle cx="4" cy="19" r="2"/>
                <circle cx="20" cy="19" r="2"/>
                <line x1="12" y1="6" x2="4.9" y2="17.1"/>
                <line x1="12" y1="6" x2="19.1" y2="17.1"/>
                <line x1="6" y1="19" x2="18" y2="19"/>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="font-display text-xl font-bold text-gray-900">AI Workflow Automation</h3>
              <p class="text-gray-600 leading-relaxed">
                Identify the repetitive tasks eating your team's time and replace them with automated workflows that run in the background — no babysitting required.
              </p>
            </div>
          </article>

          <!-- Card: Web Modernization -->
          <article class="bg-white rounded-xl border border-gray-200 p-8 flex flex-col gap-5 hover:shadow-lg transition-shadow">
            <div class="text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="3" width="20" height="18" rx="2"/>
                <line x1="2" y1="9" x2="22" y2="9"/>
                <circle cx="5.5" cy="6" r="0.8" fill="currentColor" stroke="none"/>
                <circle cx="8.5" cy="6" r="0.8" fill="currentColor" stroke="none"/>
                <line x1="7" y1="13.5" x2="17" y2="13.5"/>
                <line x1="7" y1="16.5" x2="13" y2="16.5"/>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="font-display text-xl font-bold text-gray-900">Web Modernization</h3>
              <p class="text-gray-600 leading-relaxed">
                Update outdated sites and apps so they're faster, easier to maintain, and ready to connect with the modern tools your business actually runs on.
              </p>
            </div>
          </article>

          <!-- Card: Marketing Automation -->
          <article class="bg-white rounded-xl border border-gray-200 p-8 flex flex-col gap-5 hover:shadow-lg transition-shadow">
            <div class="text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 4h18l-7 8.5V19l-4-2v-4.5L3 4z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="font-display text-xl font-bold text-gray-900">Marketing Automation</h3>
              <p class="text-gray-600 leading-relaxed">
                Set up email sequences, lead scoring, and campaign triggers so your pipeline keeps moving — without manual follow-up eating into your day.
              </p>
            </div>
          </article>

          <!-- Card: CRM & Data Pipelines -->
          <article class="bg-white rounded-xl border border-gray-200 p-8 flex flex-col gap-5 hover:shadow-lg transition-shadow">
            <div class="text-emerald-700">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <ellipse cx="12" cy="5" rx="9" ry="3"/>
                <path d="M3 5v4c0 1.657 4.03 3 9 3s9-1.343 9-3V5"/>
                <path d="M3 9v6c0 1.657 4.03 3 9 3s9-1.343 9-3V9"/>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="font-display text-xl font-bold text-gray-900">CRM &amp; Data Pipelines</h3>
              <p class="text-gray-600 leading-relaxed">
                Connect your customer data across platforms so nothing falls through the cracks and your team always has the full picture — in one place.
              </p>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- ============================================================
         ABOUT
    ============================================================ -->
    <section id="about" class="bg-white py-20 md:py-28">
      <div class="max-w-6xl mx-auto px-6">
        <p class="text-xs font-bold uppercase tracking-widest text-emerald-600 mb-14">About</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-start">

          <!-- Left: pull quote -->
          <div class="md:sticky md:top-28">
            <blockquote class="font-display text-2xl lg:text-3xl font-extrabold text-emerald-800 leading-snug">
              "I build tools that make people better at their jobs.<br class="hidden lg:block" /> Not redundant."
            </blockquote>
            <div class="mt-8 w-12 h-1 bg-emerald-500 rounded-full"></div>
          </div>

          <!-- Right: story -->
          <div class="flex flex-col gap-6 text-gray-600 leading-relaxed">
            <p>
              I started Tumulty because I kept seeing the same pattern: businesses investing in software nobody actually used, or chasing AI headlines that had nothing to do with how their teams worked day to day.
            </p>
            <p>
              My approach starts with listening. Before I recommend anything, I want to understand how your business actually runs — what tools your team lives in, where the friction is, and what a good day looks like for the people doing the work.
            </p>
            <p>
              Automation should free your team up to do the things only humans can do. When I build a workflow or modernize a system, the measure of success isn't whether the technology is impressive. It's whether your team is less stressed and more effective the week after we launch.
            </p>
            <p class="font-bold text-gray-900">
              I take that personally.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- placeholder — CTA banner next -->
  </main>
</Layout>
